# ══════════════════════════════════════════════════════════════════════════════
#  JustGate – Environment Configuration
#
#  Copy this file to .env inside the deploy/ folder, then fill in the values.
#    cp .env.example .env
#
#  The docker-compose files read this .env file automatically when run from
#  inside the deploy/ directory.
# ══════════════════════════════════════════════════════════════════════════════

# ── Ports ────────────────────────────────────────────────────────────────────

# Host port mapped to the admin UI (Next.js). Default: 3000
# Only affects which port is reachable on the host / in the reverse proxy.
# The container always listens on 3000 internally.
# FRONTEND_PORT=3000

# Host port mapped to the backend / gateway API. Default: 9090
# The container always listens on 9090 internally.
# BACKEND_PORT=9090

# ── Image version ─────────────────────────────────────────────────────────────

# Tag of the ghcr.io/justlabv1/justgate image to use.
# Defaults to "latest" if not set.  Pin to a specific release for production,
# e.g.:  JUSTGATE_VERSION=v1.0.9
JUSTGATE_VERSION=latest

# ── Required secrets ──────────────────────────────────────────────────────────

# Random secret for NextAuth session encryption (minimum 32 characters).
# Generate one with:  openssl rand -hex 32
NEXTAUTH_SECRET=change-me-use-openssl-rand-hex-32

# Shared HS256 secret between the frontend and backend (admin JWT signing).
# Must be the same value in both services.
# Generate one with:  openssl rand -hex 32
JUST_GATE_BACKEND_JWT_SECRET=change-me-use-openssl-rand-hex-32

# ── Public URL ────────────────────────────────────────────────────────────────

# The full public URL where JustGate is reachable.
# Used by NextAuth for OAuth redirect callbacks.
# For a local installation use: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ── PostgreSQL credentials (docker-compose.postgres.yml only) ─────────────────

# These are used both by the Postgres container and to build the connection URL
# that the backend receives. Keep them in sync.
POSTGRES_USER=justgate
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=justgate

# ── Optional: initial local admin account ─────────────────────────────────────

# If set, JustGate will register this email as a platform admin on first start.
# The password is set via the /register endpoint or the sign-in page afterwards.
# JUSTGATE_INITIAL_ADMIN_EMAIL=admin@example.com

# ── Optional: OIDC / SSO ──────────────────────────────────────────────────────

# JUST_GATE_OIDC_ISSUER=https://accounts.example.com/realms/my-realm
# JUST_GATE_OIDC_CLIENT_ID=justgate
# JUST_GATE_OIDC_CLIENT_SECRET=your-oidc-client-secret
# JUST_GATE_OIDC_NAME=SSO

# ── Optional: Redis ───────────────────────────────────────────────────────────

# Enables distributed rate-limiting and pub/sub when running multiple replicas.
# JUST_GATE_REDIS_URL=redis://redis:6379

# ── Optional: extra CA certificate ────────────────────────────────────────────

# Path *inside the container* to a PEM CA bundle for upstream TLS verification.
# Mount your cert file via a volume and point this variable to the container path.
# JUST_GATE_EXTRA_CA_FILE=/certs/my-ca.pem
# ── WebSocket / reverse-proxy ─────────────────────────────────────────────────

# The browser connects to the backend directly for WebSocket (live audit,
# topology map).  By default the frontend derives this URL from NEXTAUTH_URL,
# which only works when your reverse proxy forwards /api/v1/* to the backend.
#
# On Coolify / Traefik the frontend (port 3000) and backend (port 9090) must
# each have their own domain entry, OR you configure a path-based rule in
# Traefik.  The easiest approach:
#   1. In Coolify, add a second domain for port 9090, e.g.:
#        api.justgate.example.com  → container port 9090
#   2. Set:
#        JUST_GATE_PUBLIC_BACKEND_URL=https://api.justgate.example.com
#
# Leave unset/empty if your reverse proxy already routes /api/v1/* to port 9090
# (e.g. nginx with a location block).
# JUST_GATE_PUBLIC_BACKEND_URL=https://api.justgate.example.com